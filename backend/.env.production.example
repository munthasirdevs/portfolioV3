# ──────────────────────────────────────────────────────────────────────────────
# Backend Environment — Production
# ──────────────────────────────────────────────────────────────────────────────

APP_NAME="Developer Portfolio API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api.yourdomain.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=${DB_HOST}
DB_PORT=5432
DB_DATABASE=portfolio_production
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}

BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
CACHE_PREFIX=portfolio_
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

REDIS_HOST=${REDIS_HOST}
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=api.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=${RESEND_API_KEY}
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=yourdomain.com
SESSION_DOMAIN=.yourdomain.com

OCTANE_SERVER=swoole

REVERB_APP_ID=portfolio-app
REVERB_APP_KEY=${REVERB_APP_KEY}
REVERB_APP_SECRET=${REVERB_APP_SECRET}
REVERB_HOST=api.yourdomain.com
REVERB_PORT=443
REVERB_SCHEME=https

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=portfolio-media-production
AWS_USE_PATH_STYLE_ENDPOINT=false

OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_ORGANIZATION=${OPENAI_ORGANIZATION}
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

ANALYTICS_DRIVER=database
RATE_LIMIT_API=60
RATE_LIMIT_AUTH=5
