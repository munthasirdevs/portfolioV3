# ──────────────────────────────────────────────────────────────────────────────
# Backend Environment — Development
# ──────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME="Developer Portfolio API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8081

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=portfolio_dev
DB_USERNAME=portfolio_user
DB_PASSWORD=portfolio_secret

# Session & Cache
BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
CACHE_PREFIX=portfolio_
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Mail (Mailpit for local dev)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@portfolio.local"
MAIL_FROM_NAME="${APP_NAME}"

# API
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

# Octane
OCTANE_SERVER=swoole

# Reverb (WebSockets)
REVERB_APP_ID=portfolio-app
REVERB_APP_KEY=portfolio-reverb-key
REVERB_APP_SECRET=portfolio-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http

# Filesystem
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# OpenAI (AI Features)
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Analytics
ANALYTICS_DRIVER=database

# Rate Limiting
RATE_LIMIT_API=120
RATE_LIMIT_AUTH=10
