# ──────────────────────────────────────────────────────────────────────────────
# Frontend Environment — Development
# ──────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Developer Portfolio"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8081/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:6001

# Next.js
NEXT_PUBLIC_ENABLE_SSR=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Analytics (disabled in dev)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=

# Feature Flags
NEXT_PUBLIC_AI_CHAT_ENABLED=true
NEXT_PUBLIC_LIVE_METRICS_ENABLED=true
NEXT_PUBLIC_CODE_PLAYGROUND_ENABLED=true
NEXT_PUBLIC_URL_SHORTENER_ENABLED=true
