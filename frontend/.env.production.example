# ──────────────────────────────────────────────────────────────────────────────
# Frontend Environment — Production
# ──────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_NAME="Developer Portfolio"
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# API Configuration
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# Next.js
NEXT_PUBLIC_ENABLE_SSR=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# Feature Flags
NEXT_PUBLIC_AI_CHAT_ENABLED=true
NEXT_PUBLIC_LIVE_METRICS_ENABLED=true
NEXT_PUBLIC_CODE_PLAYGROUND_ENABLED=true
NEXT_PUBLIC_URL_SHORTENER_ENABLED=true
